# Base URL of the backend API. Defaults to the local Quarkus dev port.
VITE_API_BASE_URL=http://localhost:8080

# Establishment slug used in development, where there is no subdomain to
# resolve it from. Defaults to the demo establishment seeded by Flyway.
VITE_ESTABLISHMENT_SLUG=le-cormoran

# Stripe publishable key from the same test account as the backend secret key.
# Required only to display and confirm the Payment Element in development.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
