# Domain values come from config/domains/development.env for `npm run dev`
# and config/domains/production.env for `npm run build`. Do not duplicate
# them here. VITE_* overrides are reserved for an explicit nonstandard test.

# Optional fallback used only when Commande is opened outside a configured
# establishment subdomain. The wildcard local domain does not need it.
VITE_ESTABLISHMENT_SLUG=le-cormoran

# Stripe publishable key from the same test account as the backend secret key.
# Required only to display and confirm the Payment Element in development.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
