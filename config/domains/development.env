# Public local domain topology. This file contains no secret.
# Every application URL is derived from APP_BASE_DOMAIN by the central loader.
APP_SCHEME=https
APP_BASE_DOMAIN=surplasse.test

# Problem Details identifiers stay canonical across every runtime environment.
PROBLEM_TYPE_BASE=https://surplasse.com/problems/

# Restaurateur cookies stay host-only on the API. Keep this value empty.
COOKIE_DOMAIN=

# Direct subdomains that can never be interpreted as establishment slugs.
RESERVED_SUBDOMAINS=www,api,dashboard,docs,app,admin,local,mail,reports,grafana
