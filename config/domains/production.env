# Public production domain topology. This file contains no secret.
APP_SCHEME=https
APP_BASE_DOMAIN=surplasse.com
APP_BASE_URL=https://surplasse.com
ONBOARDING_URL=https://surplasse.com
DASHBOARD_URL=https://dashboard.surplasse.com
API_URL=https://api.surplasse.com

# These services are development-only and deliberately have no production URL.
LOCAL_CONTROL_URL=
DOCS_URL=https://docs.surplasse.com
MAILPIT_URL=

# Problem Details identifiers stay canonical across every runtime environment.
PROBLEM_TYPE_BASE=https://surplasse.com/problems/

# Restaurateur cookies stay host-only on the API. Keep this value empty.
COOKIE_DOMAIN=

# Direct subdomains that can never be interpreted as establishment slugs.
RESERVED_SUBDOMAINS=www,api,dashboard,docs,app,admin,local,mail
