# Copy this file outside the repository on the Ubuntu VPS, protect it with
# mode 0600, replace every change-me value, then set SURPLASSE_SECRETS_FILE to
# its absolute path. Public domains still come only from production.env.
COMPOSE_PROJECT_NAME=surplasse
IMAGE_REGISTRY=ghcr.io/nclsppr/surplasse
IMAGE_TAG=change-me-git-sha

COMPOSE_NETWORK_SUBNET=172.31.0.0/24
COMPOSE_NETWORK_IP_RANGE=172.31.0.128/25
CADDY_INTERNAL_IP=172.31.0.10
CADDY_HTTP_BIND_ADDRESS=0.0.0.0
CADDY_HTTPS_BIND_ADDRESS=0.0.0.0
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=surplasse
POSTGRES_USER=surplasse
POSTGRES_PASSWORD=change-me

STRIPE_SECRET_KEY=change-me
STRIPE_PAYMENT_WEBHOOK_SECRET=change-me
STRIPE_ACCOUNT_WEBHOOK_SECRET=change-me
STRIPE_LIVE_MODE=true
VITE_STRIPE_PUBLISHABLE_KEY=change-me

AUTH_JWT_PRIVATE_KEY_FILE=/etc/surplasse/secrets/jwt-private.pem
AUTH_JWT_JWKS_FILE=/etc/surplasse/secrets/jwks.json
AUTH_JWT_KEY_ID=change-me
AUTH_JWT_AUDIENCE=surplasse-dashboard

SMTP_HOST=change-me
SMTP_PORT=587
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_FROM=change-me
SMTP_TLS=false
SMTP_START_TLS=REQUIRED

PROMETHEUS_RETENTION_TIME=15d
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=change-me
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_SECRET_KEY=change-me

# Select the provider before the first production build. Example module names
# are documented by the official Caddy DNS provider repositories.
CADDY_DNS_MODULE=change-me
CADDY_DNS_PROVIDER=change-me
DNS_API_TOKEN=change-me

ONBOARDING_STRIPE_PILOT_ENABLED=false
