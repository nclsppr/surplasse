# Non-secret settings for the local Compose deployment.
COMPOSE_PROJECT_NAME=surplasse
IMAGE_REGISTRY=surplasse
IMAGE_TAG=development

COMPOSE_NETWORK_SUBNET=172.30.0.0/24
COMPOSE_NETWORK_IP_RANGE=172.30.0.128/25
CADDY_INTERNAL_IP=172.30.0.10
CADDY_HTTP_BIND_ADDRESS=127.0.0.1
CADDY_HTTPS_BIND_ADDRESS=127.0.0.1
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

POSTGRES_DB=surplasse
POSTGRES_USER=surplasse
POSTGRES_PASSWORD=surplasse-development-only

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_START_TLS=DISABLED

PROMETHEUS_RETENTION_TIME=7d
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=surplasse-development-only
GRAFANA_SECRET_KEY=surplasse-development-secret-key-only

ONBOARDING_STRIPE_PILOT_ENABLED=true
STRIPE_LIVE_MODE=false
