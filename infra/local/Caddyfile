{
	admin unix//var/run/surplasse-local/caddy-admin.sock
	auto_https off
	persist_config off
}

(local_forwarded_headers) {
	# Caddy also sets X-Forwarded-Host and X-Forwarded-Proto from the trusted
	# incoming request by default; keep the original Host explicit here.
	header_up Host {http.request.host}
}

https://{$APP_BASE_DOMAIN}, https://*.{$APP_BASE_DOMAIN} {
	bind 127.0.0.1
	tls {$SURPLASSE_LOCAL_CERT_FILE} {$SURPLASSE_LOCAL_KEY_FILE}

	@proxy_identity {
		host {$SURPLASSE_LOCAL_CONTROL_HOST}
		path /.well-known/surplasse-local-proxy
	}
	handle @proxy_identity {
		respond "surplasse-local-proxy-v1\n" 200
	}

	@api_dashboard {
		host {$SURPLASSE_API_HOST}
		header Origin {$DASHBOARD_URL}
	}
	handle @api_dashboard {
		reverse_proxy 127.0.0.1:8080 {
			import local_forwarded_headers
			header_down Access-Control-Allow-Credentials "true"
		}
	}

	@api_onboarding {
		host {$SURPLASSE_API_HOST}
		header Origin {$ONBOARDING_URL}
	}
	handle @api_onboarding {
		reverse_proxy 127.0.0.1:8080 {
			import local_forwarded_headers
			header_down Access-Control-Allow-Credentials "true"
		}
	}

	@api host {$SURPLASSE_API_HOST}
	handle @api {
		reverse_proxy 127.0.0.1:8080 {
			import local_forwarded_headers
			header_down -Access-Control-Allow-Credentials
		}
	}

	@dashboard host {$SURPLASSE_DASHBOARD_HOST}
	handle @dashboard {
		reverse_proxy 127.0.0.1:5174 {
			import local_forwarded_headers
		}
	}

	@docs_root {
		host {$SURPLASSE_DOCS_HOST}
		path /
	}
	handle @docs_root {
		rewrite * /surplasse/docs/
		reverse_proxy 127.0.0.1:5005 {
			import local_forwarded_headers
		}
	}

	@docs host {$SURPLASSE_DOCS_HOST}
	handle @docs {
		reverse_proxy 127.0.0.1:5005 {
			import local_forwarded_headers
		}
	}

	@local_control host {$SURPLASSE_LOCAL_CONTROL_HOST}
	handle @local_control {
		reverse_proxy 127.0.0.1:4174 {
			import local_forwarded_headers
		}
	}

	@mailpit host {$SURPLASSE_MAILPIT_HOST}
	handle @mailpit {
		reverse_proxy 127.0.0.1:8025 {
			import local_forwarded_headers
		}
	}

	@www host www.{$APP_BASE_DOMAIN}
	handle @www {
		redir {$APP_BASE_URL}{uri} 308
	}

	@website_content {
		host {$APP_BASE_DOMAIN}
		path / /index.html /creer.html /runtime-config.js /brand/*
	}
	handle @website_content {
		rewrite / /frontends/onboarding/index.html
		rewrite /index.html /frontends/onboarding/index.html
		rewrite /creer.html /frontends/onboarding/creer.html
		rewrite /runtime-config.js /frontends/onboarding/runtime-config.js
		reverse_proxy 127.0.0.1:4173 {
			import local_forwarded_headers
		}
	}

	@website host {$APP_BASE_DOMAIN}
	handle @website {
		respond "This path is not exposed by the local Surplasse website.\n" 404
	}

	@reserved host app.{$APP_BASE_DOMAIN} admin.{$APP_BASE_DOMAIN}
	handle @reserved {
		respond "This Surplasse subdomain is reserved but has no local module yet.\n" 503
	}

	handle {
		reverse_proxy 127.0.0.1:5173 {
			import local_forwarded_headers
		}
	}
}
