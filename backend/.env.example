# Stripe test keys (docs/developpement/index.md). Real values live in .env,
# ignored by git; no secret is ever committed, not even test ones.
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret, printed by: stripe listen --forward-to localhost:8080/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Magic-link landing page in the future local Dashboard.
AUTH_MAGIC_LINK_LANDING_URL=http://localhost:5174/auth/magic-link
# Cookies stay insecure only on local HTTP; production defaults to true.
AUTH_SECURE_COOKIES=false
# JWT issuer expected by the local in-memory verifier.
AUTH_JWT_ISSUER=https://api.surplasse.com
# JWT audience reserved for the Dashboard.
AUTH_JWT_AUDIENCE=surplasse-dashboard
# Demonstration sender used by Mailpit; no real address is contacted.
SMTP_FROM=no-reply@surplasse.local

# Production only. Keep these commented in a local .env. Ubuntu mounts the
# private key and public JWK set outside the image and injects SMTP secrets.
# Current RS256 private signing key, mounted read-only outside the image.
# AUTH_JWT_PRIVATE_KEY_PATH=/run/secrets/surplasse-jwt-private.pem
# Key identifier added to every JWT header.
# AUTH_JWT_KEY_ID=surplasse-2026-07
# Public JWK set containing the current and previous verification keys.
# AUTH_JWT_JWKS_PATH=/run/secrets/surplasse-jwks.json
# Transactional SMTP provider host.
# SMTP_HOST=smtp.example.invalid
# Transactional SMTP provider port.
# SMTP_PORT=587
# Transactional SMTP account name.
# SMTP_USERNAME=smtp-user
# Transactional SMTP account secret.
# SMTP_PASSWORD=replace-me
# Enable direct TLS only when the provider uses an SMTPS port.
# SMTP_TLS=false
# Require STARTTLS on conventional submission ports.
# SMTP_START_TLS=REQUIRED
