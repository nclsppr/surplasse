---
import DocsLayout from "../layouts/DocsLayout.astro";
import {
  getDocsStaticPaths,
  getDocsPageProps,
  getSidebar,
  getPrevNext,
  getBreadcrumbs,
  getEditUrl,
  getTOC,
} from "@cloudflare/nimbus-docs";
import { config } from "virtual:nimbus/config";
import { components } from "../components";
import {
  absoluteSiteUrl,
  prefixNavigationHrefs,
  withBase,
  withoutBase,
} from "@/lib/urls";
import type { GetStaticPaths } from "astro";

export const prerender = true;
export const getStaticPaths: GetStaticPaths = async (options) =>
  (await getDocsStaticPaths(options)).map((route) =>
    route.params.slug === "index"
      ? { ...route, params: { slug: undefined } }
      : route,
  );

const { entry, Content, headings } = await getDocsPageProps(Astro);

const currentSlug =
  withoutBase(Astro.url.pathname).replace(/\/$/, "") || "/";

// Column renders only when not custom mode AND site-wide flag on AND page hasn't opted out.
const isCustom = entry.data.mode === "custom";
const sidebarOn =
  !isCustom &&
  config.features?.sidebar !== false &&
  entry.data.sidebar !== false;
const tocOn =
  !isCustom &&
  config.features?.tableOfContents !== false &&
  entry.data.tableOfContents !== false;

const rawSidebar = sidebarOn
  ? await getSidebar(currentSlug, { collection: entry.collection })
  : false;
const prevNext = await getPrevNext(currentSlug, {
  sidebarTree: rawSidebar === false ? [] : rawSidebar,
  overrides: { prev: entry.data.prev, next: entry.data.next },
});
// Pass `collection` so versioned pages (docs-<v>) get version-prefixed
// breadcrumb hrefs — parity with the getSidebar call above.
const breadcrumbs = await getBreadcrumbs(currentSlug, { collection: entry.collection });
const editUrl = await getEditUrl(entry);
// The generated Nimbus copy has no meaningful Git history. A date is shown
// only when the source Markdown declares one explicitly.
const lastUpdated = entry.data.lastUpdated;
// `tocOn` already implies `tableOfContents !== false`, but TS can't carry
// that boolean narrowing to the value here — re-check it so `getTOC` only
// ever sees its options object (or undefined), never `false`.
const tocConfig = entry.data.tableOfContents;
const toc = tocOn && tocConfig !== false ? getTOC(headings, tocConfig) : false;
const markdownPath =
  entry.id === "index" ? "/index.md" : `/${entry.id}/index.md`;
const markdownUrl = Astro.site
  ? absoluteSiteUrl(markdownPath, Astro.site)
  : withBase(markdownPath);
const socialImage =
  entry.data.socialImage ??
  withBase(entry.id === "index" ? "/og.png" : `/og/${entry.id}.png`);
const sidebar =
  rawSidebar === false ? false : prefixNavigationHrefs(rawSidebar);
const renderedPrevNext = prefixNavigationHrefs(prevNext);
const renderedBreadcrumbs = prefixNavigationHrefs(breadcrumbs);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sidebar={sidebar}
  headings={toc}
  breadcrumbs={renderedBreadcrumbs}
  prevNext={renderedPrevNext}
  mode={entry.data.mode}
  banner={entry.data.banner}
  head={entry.data.head}
  searchable={entry.data.searchable}
  noindex={entry.data.noindex}
  markdownUrl={markdownUrl}
  socialImage={socialImage}
  lastUpdated={lastUpdated}
  editUrl={editUrl}
  draft={entry.data.draft}
  audience={entry.data.audience}
  collection={entry.collection}
  entryId={entry.id}
>
  <Content components={components} />
</DocsLayout>
