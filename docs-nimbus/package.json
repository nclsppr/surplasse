{
  "name": "docs-nimbus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "predev": "npm run sync",
    "dev": "astro dev",
    "prebuild": "npm run sync",
    "build": "astro build",
    "preview": "astro preview",
    "pretypecheck": "npm run sync",
    "typecheck": "astro check",
    "prelint:docs": "npm run sync",
    "lint:docs": "nimbus-docs lint",
    "lint:docs:fix": "nimbus-docs lint --fix",
    "test": "node --test scripts/*.test.mjs",
    "check": "npm run test && npm run typecheck && npm run build && npm run lint:docs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@iconify-json/ph": "^1.2.0",
    "@cloudflare/nimbus-docs": "0.7.1",
    "astro": "^7.0.0",
    "astro-icon": "^1.1.0",
    "astro-og-canvas": "^0.13.0",
    "canvaskit-wasm": "^0.41.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.1.4",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  }
}
